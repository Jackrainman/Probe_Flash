# Lark application credentials — fill from Feishu developer console
LARK_APP_ID=
LARK_APP_SECRET=

# Bot's own open_id (used to detect "@bot" mentions in group chats)
LARK_BOT_OPEN_ID=

# Lark domain: feishu (国内) or lark (海外)
LARK_DOMAIN=feishu

# Skill dispatch mode: mock | claude | deepseek
# - mock: returns stub text, no LLM call (备赛期 MVP 默认)
# - claude: calls Anthropic API (requires ANTHROPIC_API_KEY, not implemented in MVP)
# - deepseek: calls DeepSeek API (requires DEEPSEEK_API_KEY, not implemented in MVP)
PROBEFLASH_SKILL_MODE=mock

# When ready to enable real checklist generation, add provider key here:
# ANTHROPIC_API_KEY=sk-ant-xxx
# DEEPSEEK_API_KEY=sk-xxx
